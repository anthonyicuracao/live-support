PORT=8000

# ─── Authentication ──────────────────────────────────────────────────────
# Built-in username/password auth with per-tenant users (see auth.go).
# Agents sign in at /login?ref=<tenant>; admins manage accounts at /users.
#
# The first time a tenant is used, an initial admin account is created with
# ADMIN_USERNAME. If ADMIN_INITIAL_PASSWORD is empty, a temporary password is
# generated and printed to the server log (must be changed on first login).
ADMIN_USERNAME=
ADMIN_INITIAL_PASSWORD=

# Session / invite / password-reset link lifetimes, in hours.
SESSION_TTL_HOURS=168
INVITE_TTL_HOURS=72
RESET_TTL_HOURS=24

# Set true when serving over HTTPS so cookies are marked Secure.
SECURE_COOKIES=false

# Site name shown on the sign-in and user-management pages.
SITE_NAME=

# CONNECT_SECRET — shared secret for platform sign-in hand-off links
# (/handoff?t=<token>). Paste it into the integrating platform's settings
# (e.g. the admin dashboard's Live Support card). Leave unset to have one
# generated, appended to this file, and printed to the log on first run.

# Cloudflare TURN (optional — falls back to public STUN without these)
CLOUDFLARE_TURN_TOKEN_ID=
CLOUDFLARE_API_TOKEN=

PRIMARY_COLOR=
FAVICON_URL=

# Shared secret for platform hand-off links (auto-generated on first run).
CONNECT_SECRET=
