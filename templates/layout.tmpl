<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{block "title" .}}{{.SiteName}}{{end}}</title>
  <link rel="icon" href="{{.FaviconURL}}">
  <style>
    :root { --primary: {{.PrimaryColor}}; }
    * { box-sizing: border-box; }
    body {
      margin: 0; min-height: 100vh; background: #f4f5f7; color: #1f2328;
      font: 15px/1.5 -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
      display: flex; flex-direction: column; align-items: center;
    }
    main.container { width: 100%; max-width: 420px; padding: 48px 16px; }
    main.container.wide { max-width: 880px; }
    .card { background: #fff; border: 1px solid #e3e6ea; border-radius: 10px; padding: 24px; }
    h1 { font-size: 22px; margin: 0 0 4px; }
    h3 { margin: 0 0 12px; }
    .lede { color: #57606a; margin: 0 0 16px; }
    .muted { color: #57606a; }
    .form-row { margin-bottom: 14px; }
    label { display: block; font-weight: 600; margin-bottom: 4px; }
    input, select {
      width: 100%; padding: 8px 10px; border: 1px solid #cdd3da; border-radius: 6px;
      font: inherit; background: #fff;
    }
    input:focus, select:focus { outline: 2px solid var(--primary); outline-offset: -1px; border-color: var(--primary); }
    .btn {
      display: inline-block; padding: 8px 14px; border-radius: 6px; border: 1px solid #cdd3da;
      background: #fff; font: inherit; font-weight: 600; cursor: pointer;
    }
    .btn.primary { background: var(--primary); border-color: var(--primary); color: #fff; }
    .btn.ghost { background: transparent; }
    .btn.danger { color: #b42318; }
    .notice { border-radius: 6px; padding: 10px 12px; margin: 0 0 16px; }
    .notice.err { background: #fdecea; border: 1px solid #f5c6c0; color: #b42318; }
    .notice.ok { background: #e7f5ec; border: 1px solid #bfe3cd; color: #135f2e; }
    .notice .code {
      display: block; margin-top: 6px; padding: 6px 8px; background: #fff; border: 1px dashed #cdd3da;
      border-radius: 4px; font-family: ui-monospace, monospace; font-size: 12px; word-break: break-all;
      user-select: all;
    }
    a { color: var(--primary); }
    table { width: 100%; border-collapse: collapse; }
    th, td { text-align: left; padding: 8px 10px; border-bottom: 1px solid #eceff2; vertical-align: middle; }
    th { color: #57606a; font-size: 13px; }
    .admin-head { display: flex; justify-content: space-between; align-items: center; margin-bottom: 16px; }
    .admin-nav { display: flex; gap: 14px; align-items: center; }
    .inline { display: inline; }
    .toolbar { display: flex; gap: 12px; align-items: flex-end; flex-wrap: wrap; }
    .toolbar label { flex: 1 1 160px; font-weight: 600; }
  </style>
</head>
<body>
  <main class="container{{if .Wide}} wide{{end}}">
    {{template "content" .}}
  </main>
</body>
</html>
